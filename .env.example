# Nina — environment

# Docker image (compose service `nina`)
# - `make docker-start` overrides this automatically to REGISTRY/IMAGE:$(git sha)
NINA_IMAGE=carlosrabelo/nina:latest

# Paths — repo-relative for `nina` / `make` on the host. Inside Docker, `load_project_dotenv`
# adds a leading `/` when the value is not already absolute (volume `./data:/data`).
DATA_DIR=data/db
TOKENS_DIR=data/tokens
SESSIONS_DIR=data/sessions
GOOGLE_CREDENTIALS_FILE=data/credentials/credentials.json

# HTTP (compose port publishing)
NINA_HTTP_HOST=0.0.0.0
NINA_HTTP_PORT=8765

# Timezone (containers)
# Note: for GMT-04, use Etc/GMT+4 (POSIX sign is inverted)
TZ=Etc/GMT+4
PGTZ=Etc/GMT+4

# PostgreSQL (primary storage).
# Recommended: set POSTGRES_* only. `nina` builds `DATABASE_URL` automatically:
#   - On the host: postgresql://USER:PASS@127.0.0.1:PORT/DB (override host with POSTGRES_HOST)
#   - In Docker:   postgresql://USER:PASS@postgres:PORT/DB (override with POSTGRES_HOST)
# Optional: set `DATABASE_URL` yourself if you need extra query params (e.g. ?sslmode=require).
POSTGRES_DB=nina
POSTGRES_USER=nina
POSTGRES_PASSWORD=nina
POSTGRES_PORT=5432
# POSTGRES_HOST=

# Telegram user client — my.telegram.org → API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram bot — @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# LLM — format: provider/model  (groq, openai, anthropic, ollama)
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# API key — protects HTTP API (header X-Api-Key)
NINA_API_KEY=
