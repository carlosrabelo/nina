# ─────────────────────────────────────────────────────────────────────────────
# Nina — environment configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Path to credentials.json downloaded from Google Cloud Console.
# Steps:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Desktop app)
#   3. Download the JSON and place it at the path below
GOOGLE_CREDENTIALS_FILE=credentials/credentials.json

# Directory where per-account OAuth tokens are stored after authentication.
# Each account gets its own file: tokens/<account>.json
# These files contain refresh tokens — do not commit them.
TOKENS_DIR=tokens

# Directory for application state (presence, workdays, profile, locale,
# notifications, and the SQLite database).
DATA_DIR=data

# Directory for session files (Telegram bot offset, Telethon session).
SESSIONS_DIR=sessions

# ── Obsidian ──────────────────────────────────────────────────────────────────
# Path to your Obsidian vault folder where Nina will write its pages.
# Leave empty to disable Obsidian integration.
# OBSIDIAN_VAULT_PATH=/vault

# CouchDB credentials for Obsidian LiveSync (docker-compose obsidian-livesync service).
# COUCHDB_USER=nina
# COUCHDB_PASSWORD=changeme

# ── Telegram User Client (Telethon) ───────────────────────────────────────────
# Allows Nina to read/send messages as you (your personal account).
# Get API credentials at https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Telegram Bot (BotFather) ───────────────────────────────────────────────────
# Allows you to send commands to Nina via a Telegram bot.
# Steps:
#   1. Open Telegram → talk to @BotFather → /newbot → follow prompts
#   2. Copy the token below
#   3. Run: make tg-bot
#   4. Send /start to your new bot in Telegram
#   5. Run: make tg-bot again — it will print your chat ID
#   6. Copy that number to TELEGRAM_OWNER_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# ── LLM (LiteLLM — unified provider interface) ────────────────────────────────
# Format: <provider>/<model_name>
# Examples:
#   groq/llama-3.3-70b-versatile   (fast, free tier available)
#   openai/gpt-4o-mini
#   anthropic/claude-haiku-4-5-20251001
#   ollama/llama3.2                 (local, no key needed)
LLM_MODEL=groq/llama-3.3-70b-versatile

# API key for the chosen provider (only the relevant one is required)
GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional tuning
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=1024
