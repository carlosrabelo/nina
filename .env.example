# Nina — environment

# Docker image (compose service `nina`)
# - `make docker-start` overrides this automatically to REGISTRY/IMAGE:$(git sha)
NINA_IMAGE=carlosrabelo/nina:latest

# Docker runtime paths (inside containers)
GOOGLE_CREDENTIALS_FILE=/data/credentials/credentials.json
TOKENS_DIR=/data/tokens
SESSIONS_DIR=/data/sessions
DATA_DIR=/data/db

# Host overrides (used by `make run` / `make console`)
GOOGLE_CREDENTIALS_FILE_HOST=data/credentials/credentials.json
TOKENS_DIR_HOST=data/tokens
SESSIONS_DIR_HOST=data/sessions
DATA_DIR_HOST=data/db

# HTTP (compose port publishing)
NINA_HTTP_HOST=0.0.0.0
NINA_HTTP_PORT=8765

# Timezone (containers)
# Note: for GMT-04, use Etc/GMT+4 (POSIX sign is inverted)
TZ=Etc/GMT+4
PGTZ=Etc/GMT+4

# PostgreSQL (primary storage)
# Host example:
# DATABASE_URL_HOST=postgresql://nina:nina@localhost:5432/nina
DATABASE_URL_HOST=
# Docker example:
# DATABASE_URL=postgresql://nina:nina@postgres:5432/nina
DATABASE_URL=
# If you want to override DB bootstrap defaults used by docker-compose:
POSTGRES_DB=nina
POSTGRES_USER=nina
POSTGRES_PASSWORD=nina
POSTGRES_PORT=5432

# Telegram user client — my.telegram.org → API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram bot — @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# LLM — format: provider/model  (groq, openai, anthropic, ollama)
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# API key — protects HTTP API (header X-Api-Key)
NINA_API_KEY=
