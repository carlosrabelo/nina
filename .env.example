# ─────────────────────────────────────────────────────────────────────────────
# Nina — environment configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Path to credentials.json downloaded from Google Cloud Console.
# Steps:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Desktop app)
#   3. Download the JSON and place it at the path below
GOOGLE_CREDENTIALS_FILE=credentials/credentials.json

# Directory where per-account OAuth tokens are stored after authentication.
# Each account gets its own file: tokens/<account>.json
# These files contain refresh tokens — do not commit them.
TOKENS_DIR=tokens
